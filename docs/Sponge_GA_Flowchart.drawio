<mxfile host="65bd71144e">
    <diagram id="SpongeGA-Flowchart" name="Flowchart">
        <mxGraphModel dx="2653" dy="2351" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n    %% Define Nodes\n    Start([START])\n    Input[/Input: Background Image, Population P=30, Generations G=50, Mutation Rate pm=0.1/]\n    Init[INITIALIZATION: Randomly generate 30 initial patches. Gen=1]\n    \n    Eval[EVALUATION: Apply patch to image -&gt; Pass to victim model -&gt; Calculate Fitness]\n    Check{Check: Gen &gt; G ?}\n    \n    BestOut[/Output: Best_Patch with the highest Fitness score/]\n    End([END])\n    \n    Select[SELECTION: Sort by Fitness descending, retain Top 10% Elite]\n    Cross[CROSSOVER: Select 2 parents from Elite, crossover to generate offspring]\n    Mutate[MUTATION: Add random noise with probability p_m]\n    Update[UPDATE: Next Population = Elite + Offspring. Gen = Gen + 1]\n\n    %% Connect Nodes\n    Start --&gt; Input\n    Input --&gt; Init\n    Init --&gt;|Loop Anchor| Eval\n    \n    Eval --&gt; Check\n    \n    %% True Branch (Termination)\n    Check --&gt;|YES| BestOut\n    BestOut --&gt; End\n    \n    %% False Branch (Continue Genetic Algorithm)\n    Check --&gt;|NO| Select\n    Select --&gt; Cross\n    Cross --&gt; Mutate\n    Mutate --&gt; Update\n    \n    %% Loop Back\n    Update --&gt;|Next Generation| Eval\n\n    %% Styling for better visualization\n    classDef oval fill:#f9f,stroke:#333,stroke-width:2px;\n    classDef io fill:#bbf,stroke:#333,stroke-width:2px;\n    classDef process fill:#fff,stroke:#333,stroke-width:2px;\n    classDef decision fill:#ff9,stroke:#333,stroke-width:2px;\n    \n    class Start,End oval;\n    class Input,BestOut io;\n    class Init,Eval,Select,Cross,Mutate,Update process;\n    class Check decision;&quot;&#xa;}" id="4">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1" parent="1">
                        <mxGeometry x="-270" y="-520" width="698.125" height="1422.5625" as="geometry"/>
                    </mxCell>
                </UserObject>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>